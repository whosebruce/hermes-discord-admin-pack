# Copy this file to an ignored local path before replacing placeholders.
# Apply with: python scripts/apply-config-lock.py --lock /path/to/local-lock.yaml
profiles:
  default:
    home: ~/.hermes
    values:
      discord.require_mention: true
      discord.auto_thread: true
      discord.auto_thread_free_response: true
      discord.free_response_channels:
        - 'YOUR_TRUSTED_CHANNEL_ID'
      discord.allowed_channels:
        - 'YOUR_TRUSTED_CHANNEL_ID'
      discord.history_backfill: true
      discord.history_backfill_limit: 50
      discord.reactions: true
      discord.bots_require_inline_mention: true
      approvals.mode: smart
