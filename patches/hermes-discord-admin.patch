+def _create_channel(
+    token: str, guild_id: str, name: str, channel_type: str = "text",
+    parent_id: Optional[str] = None, topic: Optional[str] = None,
+    position: Optional[int] = None, nsfw: Optional[bool] = None,
+    rate_limit_per_user: Optional[int] = None, bitrate: Optional[int] = None,
+    user_limit: Optional[int] = None, **_kwargs: Any,
+) -> str:
+    """Create a Discord text/voice/category/announcement/forum/stage channel."""
+    type_id = _coerce_channel_type(channel_type)
+    body: Dict[str, Any] = {"name": name, "type": type_id}
+    _put_if_present(body, "parent_id", parent_id)
+    _put_if_present(body, "topic", topic)
+    _put_if_present(body, "position", position, coerce=_optional_int)
+    _put_if_present(body, "nsfw", nsfw, coerce=_optional_bool)
+    _put_if_present(body, "rate_limit_per_user", rate_limit_per_user, coerce=_optional_int)
+    _put_if_present(body, "bitrate", bitrate, coerce=_optional_int)
+    _put_if_present(body, "user_limit", user_limit, coerce=_optional_int)
+
+    ch = _discord_request("POST", f"/guilds/{guild_id}/channels", token, body=body)
+    return json.dumps({
+        "success": True,
+        "channel_id": ch.get("id"),
+        "name": ch.get("name"),
+        "type": _channel_type_name(ch.get("type", type_id)),
+        "parent_id": ch.get("parent_id"),
+    })
+
+
+def _edit_channel(
+    token: str, channel_id: str, name: Optional[str] = None,
+    parent_id: Optional[str] = None, topic: Optional[str] = None,
+    position: Optional[int] = None, nsfw: Optional[bool] = None,
+    rate_limit_per_user: Optional[int] = None, bitrate: Optional[int] = None,
+    user_limit: Optional[int] = None, lock_permissions: Optional[bool] = None,
+    **_kwargs: Any,
+) -> str:
+    """Edit a Discord channel's common properties."""
+    body: Dict[str, Any] = {}
+    _put_if_present(body, "name", name)
+    _put_if_present(body, "parent_id", parent_id)
+    _put_if_present(body, "topic", topic)
+    _put_if_present(body, "position", position, coerce=_optional_int)
+    _put_if_present(body, "nsfw", nsfw, coerce=_optional_bool)
+    _put_if_present(body, "rate_limit_per_user", rate_limit_per_user, coerce=_optional_int)
+    _put_if_present(body, "bitrate", bitrate, coerce=_optional_int)
+    _put_if_present(body, "user_limit", user_limit, coerce=_optional_int)
+    _put_if_present(body, "lock_permissions", lock_permissions, coerce=_optional_bool)
+    if not body:
+        return json.dumps({"error": "edit_channel requires at least one editable field."})
+
+    ch = _discord_request("PATCH", f"/channels/{channel_id}", token, body=body)
+    return json.dumps({
+        "success": True,
+        "channel_id": ch.get("id"),
+        "name": ch.get("name"),
+        "type": _channel_type_name(ch.get("type", -1)),
+        "parent_id": ch.get("parent_id"),
+    })
+
+
+def _move_channel(
+    token: str, guild_id: str, channel_id: str, position: int,
+    parent_id: Optional[str] = None, lock_permissions: Optional[bool] = None,
+    **_kwargs: Any,
+) -> str:
+    """Move/reorder a Discord channel in a guild."""
+    entry: Dict[str, Any] = {"id": channel_id, "position": int(position)}
+    _put_if_present(entry, "parent_id", parent_id)
+    _put_if_present(entry, "lock_permissions", lock_permissions, coerce=_optional_bool)
+    _discord_request("PATCH", f"/guilds/{guild_id}/channels", token, body=[entry])
+    return json.dumps({"success": True, "message": f"Channel {channel_id} moved."})
+
+
+def _set_channel_permission(
+    token: str, channel_id: str, overwrite_id: str, overwrite_type: str,
+    allow: str = "0", deny: str = "0", **_kwargs: Any,
+) -> str:
+    """Create/update a channel permission overwrite for a role or member."""
+    body = {
+        "type": _coerce_overwrite_type(overwrite_type),
+        "allow": str(allow or "0"),
+        "deny": str(deny or "0"),
+    }
+    _discord_request("PUT", f"/channels/{channel_id}/permissions/{overwrite_id}", token, body=body)
+    return json.dumps({"success": True, "message": f"Permission overwrite {overwrite_id} updated."})
+
+
+def _delete_channel_permission(token: str, channel_id: str, overwrite_id: str, **_kwargs: Any) -> str:
+    """Delete a channel permission overwrite."""
+    _discord_request("DELETE", f"/channels/{channel_id}/permissions/{overwrite_id}", token)
+    return json.dumps({"success": True, "message": f"Permission overwrite {overwrite_id} deleted."})
+
+
+def _delete_channel(token: str, channel_id: str, **_kwargs: Any) -> str:
+    """Delete a Discord channel or thread."""
+    _discord_request("DELETE", f"/channels/{channel_id}", token)
+    return json.dumps({"success": True, "message": f"Channel {channel_id} deleted."})
+
