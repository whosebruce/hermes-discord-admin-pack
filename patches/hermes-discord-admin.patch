@@ -121,12 +121,72 @@ _CHANNEL_TYPE_NAMES = {
     15: "forum",
     16: "media",
 }
+_CHANNEL_TYPE_IDS = {v: k for k, v in _CHANNEL_TYPE_NAMES.items()}
+_CHANNEL_TYPE_IDS.update({
+    "news": 5,
+    "announcements": 5,
+    "public": 11,
+    "private": 12,
+})
+_OVERWRITE_TYPE_IDS = {"role": 0, "member": 1}
 
 
 def _channel_type_name(type_id: int) -> str:
     return _CHANNEL_TYPE_NAMES.get(type_id, f"unknown({type_id})")
 
 
+def _coerce_channel_type(channel_type: Any) -> int:
+    """Return Discord channel type ID from a name or integer-like value."""
+    if channel_type is None or channel_type == "":
+        return 0
+    if isinstance(channel_type, int):
+        return channel_type
+    text = str(channel_type).strip().lower()
+    if text.isdigit():
+        return int(text)
+    if text not in _CHANNEL_TYPE_IDS:
+        known = ", ".join(sorted(k for k in _CHANNEL_TYPE_IDS if not k.isdigit()))
+        raise ValueError(f"Unknown channel_type '{channel_type}'. Known: {known}")
+    return _CHANNEL_TYPE_IDS[text]
+
+
+def _coerce_overwrite_type(overwrite_type: Any) -> int:
+    """Return Discord permission overwrite type ID from role/member or int."""
+    if isinstance(overwrite_type, int):
+        return overwrite_type
+    text = str(overwrite_type).strip().lower()
+    if text.isdigit():
+        return int(text)
+    if text not in _OVERWRITE_TYPE_IDS:
+        raise ValueError("overwrite_type must be 'role' or 'member'")
+    return _OVERWRITE_TYPE_IDS[text]
+
+
+def _optional_bool(value: Any) -> Optional[bool]:
+    if value is None or value == "":
+        return None
+    if isinstance(value, bool):
+        return value
+    text = str(value).strip().lower()
+    if text in {"1", "true", "yes", "y", "on"}:
+        return True
+    if text in {"0", "false", "no", "n", "off"}:
+        return False
+    raise ValueError(f"Expected boolean value, got {value!r}")
+
+
+def _optional_int(value: Any) -> Optional[int]:
+    if value is None or value == "":
+        return None
+    return int(value)
+
+
+def _put_if_present(body: Dict[str, Any], key: str, value: Any, *, coerce: Any = None) -> None:
+    if value is None or value == "":
+        return
+    body[key] = coerce(value) if coerce else value
+
+
