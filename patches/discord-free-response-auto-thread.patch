+    def _discord_auto_thread_free_response(self) -> bool:
+        """Return whether free-response channel messages should auto-thread.
+
+        Hermes skips auto-threading in ``free_response_channels`` by default to
+        avoid surprise thread creation in chatty rooms. Command-center channels
+        can opt into free-response *and* per-request threads explicitly.
+        """
+        configured = self.config.extra.get("auto_thread_free_response")
+        if configured is not None:
+            if isinstance(configured, str):
+                return configured.lower() in {"true", "1", "yes", "on"}
+            return bool(configured)
+        return os.getenv("DISCORD_AUTO_THREAD_FREE_RESPONSE", "false").lower() in {
+            "true",
+            "1",
+            "yes",
+            "on",
+        }
+
